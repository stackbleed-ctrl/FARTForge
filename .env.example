# ─────────────────────────────────────────────────────────────────────────────
# FARTForge Environment Variables
# Copy to .env and fill in values. Never commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Core ──────────────────────────────────────────────────────────────────────

# Environment: "development" (default) or "production"
# In production, FARTFORGE_SECRET is required — missing it raises at startup.
FARTFORGE_ENV=development

# HMAC secret for event signing. Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
FARTFORGE_SECRET=replace-me-with-a-real-secret-at-least-32-chars

# ── API ───────────────────────────────────────────────────────────────────────

# API key for REST endpoint auth (optional — omit to disable auth)
FARTFORGE_API_KEY=

# Max request body size in bytes (default: 262144 = 256 KB)
FARTFORGE_MAX_BODY_BYTES=262144

# Rate limit: max requests per window (default: 60 requests / 60 seconds)
FARTFORGE_RATE_LIMIT_MAX=60
FARTFORGE_RATE_LIMIT_WINDOW=60

# CORS allowed origins (comma-separated, or * for open)
# FARTFORGE_CORS_ORIGINS=http://localhost:3000,https://your-frontend.com

# ── Solana ────────────────────────────────────────────────────────────────────

# RPC endpoint (default: mainnet-beta)
# For testing use: https://api.devnet.solana.com
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Base58 keypair JSON string for the payer account (SolanaAnchor)
# Generate a new keypair: solana-keygen new --outfile keypair.json
# Then: cat keypair.json
SOLANA_PAYER_KEYPAIR=

# SPL mint address of the $FARTFORGE token
FARTFORGE_TOKEN_MINT=FARTxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Storage ───────────────────────────────────────────────────────────────────

# Path to the SQLite database file
FARTFORGE_DB_PATH=fartforge_events.db
